def _parse_utc_date(date_str: str) -> date:
    try:
        return date.fromisoformat(date_str)  # expects YYYY-MM-DD[time+offeset]
    except ValueError as exc:
        raise argparse.ArgumentTypeError(
            f"Invalid date '{date_str}'. Expected format: YYYY-MM-DD or YYYY-MM-DD[time][offset]"
        ) from exc

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Most active cookie")
    parser.add_argument("cookie_log", help="Path to cookie log CSV file")
    parser.add_argument("-d", "--date", required=True, type=_parse_utc_date)
    return parser

def str_to_date(timestamp: str) -> date:
    return datetime.fromisoformat(timestamp).date()

def get_day_cookies_linear_scan_stop_early(cookie_log_reader : Iterator[list[str]], valid_date : date) -> list[str]:
    cookie_counter = Counter()
    for cookie, timestamp in cookie_log_reader:
        current_date = str_to_date(timestamp)
        if current_date < valid_date:
            break
        elif current_date == valid_date:
            cookie_counter[cookie] += 1
    
    max_count = max(cookie_counter.values(), default=0)
    valid_cookies = [cookie for cookie, cnt in cookie_counter.items() if cnt == max_count]
    return valid_cookies
    
def get_day_cookies(cookie_log_reader : Iterator[list[str]], date : datetime.date, testing=False) -> list[str]:
    if not testing:
        return get_day_cookies_linear_scan_stop_early(cookie_log_reader, date)
    

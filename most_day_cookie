def get_reader(file : TextIO) -> Iterator[list[str]]:
    reader = csv.reader(file)
    header = next(reader) # skip header (assume the file is not empty)
    return reader 

def main():
    parser = build_parser()
    args = parser.parse_args()
    with open(args.cookie_log, 'r') as file:
        reader = get_reader(file)
        active_cookies = get_day_cookies(reader, args.date)
        output = "\n".join(active_cookies) if active_cookies else f"No cookies on {args.date}"
    print(output)

if __name__ == "__main__":
    raise SystemExit(main())
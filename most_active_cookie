#!/usr/bin/env python3

import argparse
import csv
from collections import Counter
from datetime import date, datetime
from typing import Iterator, TextIO


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Most active cookie")
    parser.add_argument("cookie_log", help="Path to cookie log CSV file")
    parser.add_argument("-d", "--date", required=True, type=date.fromisoformat, help="Date to find most active cookies for")
    return parser

def str_to_date(timestamp: str) -> date:
    return datetime.fromisoformat(timestamp).date()

def get_most_active_cookies(cookie_log_reader: Iterator[list[str]], valid_date: date) -> list[str]:
    cookie_counter = Counter()
    for cookie, timestamp in cookie_log_reader:
        current_date = str_to_date(timestamp)
        if current_date < valid_date:
            break
        elif current_date == valid_date:
            cookie_counter[cookie] += 1
    
    max_count = max(cookie_counter.values(), default=0)
    valid_cookies = [cookie for cookie, cnt in cookie_counter.items() if cnt == max_count]
    return valid_cookies

def get_reader(file: TextIO) -> Iterator[list[str]]:
    reader = csv.reader(file)
    next(reader, None)  # skip header; None if file is empty
    return reader 

def main() -> int:
    args = build_parser().parse_args()
    with open(args.cookie_log, 'r') as file:
        reader = get_reader(file)
        active_cookies = get_most_active_cookies(reader, args.date)
        output = "\n".join(active_cookies)
    print(output, end="")
    return 0

if __name__ == "__main__":
    raise SystemExit(main())
